DATABASE_URL=postgresql+asyncpg://mini:mini@localhost:5432/mini_foundry
SYNC_DATABASE_URL=postgresql://mini:mini@localhost:5432/mini_foundry
REDIS_URL=redis://localhost:6379/0

# SECURITY: the values below are development defaults. With ENVIRONMENT=production
# the backend refuses to boot until JWT_SECRET, ENCRYPTION_KEY and ADMIN_PASSWORD
# are replaced (see app/config.py: production_hardening_issues).
# Generate strong values, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(48))"
ENVIRONMENT=development
JWT_SECRET=change-me-in-production
JWT_EXPIRES_HOURS=8
# Fernet/symmetric key for connector secrets (>=32 chars). Rotating it makes
# existing ciphertexts undecryptable.
ENCRYPTION_KEY=dev-secret-key-change-me-in-prod-32chars

ADMIN_EMAIL=admin@mini.local
ADMIN_PASSWORD=admin

# Sandbox isolation (see docs/SANDBOX_ISOLATION.md). Leave empty for local dev
# (uses the host Docker socket). In hardened deployments point at a dedicated
# rootless/remote daemon so the worker has no host-socket access.
SANDBOX_DOCKER_HOST=
# Optional hardened OCI runtime for sandbox containers, e.g. runsc (gVisor).
SANDBOX_RUNTIME=

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen3.5:4b

GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-1.5-pro

CUSTOM_AI_BASE_URL=
CUSTOM_AI_KEY=
CUSTOM_AI_DEFAULT_MODEL=

FRONTEND_PORT=3000
FRONTEND_ORIGIN=http://localhost:3000
SQL_QUERY_TIMEOUT_SECONDS=30
SQL_ROW_LIMIT=1000
